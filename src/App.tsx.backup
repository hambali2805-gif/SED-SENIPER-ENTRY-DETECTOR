type Candle = {
  t: number;
  o: number;
  h: number;
  l: number;
  c: number;
  v: number;
  qv: number;
  trades: number;
  takerBuyBase: number;
  takerBuyQuote: number;
};

type SymbolInfo = { symbol: string; baseAsset: string; quoteAsset: string; status: string };
type Ticker = { symbol: string; lastPrice: string; priceChangePercent: string; quoteVolume: string; volume: string; highPrice: string; lowPrice: string };
type MarkData = { markPrice?: string; indexPrice?: string; lastFundingRate?: string; nextFundingTime?: number };
type OiHist = { sumOpenInterest: string; sumOpenInterestValue: string; timestamp: number };
type LongShort = { symbol: string; longShortRatio: string; longAccount: string; shortAccount: string; timestamp: number };
type TakerFlow = { buySellRatio: string; buyVol: string; sellVol: string; timestamp: number };
type DepthLevel = { price: number; qty: number; notional: number };

type TfAnalysis = {
  tf: string;
  trend: 'BULLISH' | 'BEARISH' | 'RANGE' | 'NO DATA';
  score: number;
  momentum: number;
  volumeState: 'EXPANSION' | 'NORMAL' | 'LOW';
};

type Zone = { price: number; touches: number; distance: number; lastTime: number; top?: number; bottom?: number; score?: number; kind?: 'MAJOR' | 'ACTIVE' | 'EXECUTION'; broken?: boolean };
type MiniWall = DepthLevel & { distance: number; strength: number };

type FlowEngine = {
  bias: 'BULLISH' | 'BEARISH' | 'NEUTRAL';
  state: string;
  bullishScore: number;
  bearishScore: number;
  flowScore: number;
  netScore: number;
  reasons: string[];
};

type Plan = {
  status: 'LONG VALID' | 'LONG READY' | 'LONG RISKAN' | 'SHORT VALID' | 'SHORT READY' | 'SHORT RISKAN' | 'WAIT' | 'NO TRADE';
  bias: string;
  currentPrice: number;
  markPrice: number;
  entryZone?: [number, number];
  keyLevels: string;
  trigger: string;
  invalidation: string;
  tpAreas: number[];
  confidence: number;
  confluenceScore?: number;
  structureScore?: number;
  obScore?: number;
  snrScore?: number;
  flowScorePart?: number;
  liquidityScore?: number;
  flowNote: string;
  warning: string;
};

type OrderBlock = {
  type: 'BULLISH_OB' | 'BEARISH_OB';
  top: number;
  bottom: number;
  startIndex: number;
  sourceTime: number;
  mitigated: boolean;
  invalidated: boolean;
  quality: 'STRONG' | 'MEDIUM' | 'WEAK';
  strength: number;
  distance: number;
};

type StructurePoint = { index: number; price: number; label: 'HH' | 'HL' | 'LH' | 'LL'; side: 'high' | 'low'; time: number };
type StructureEvent = { index: number; price: number; label: 'BOS UP' | 'BOS DOWN' | 'CHoCH UP' | 'CHoCH DOWN'; time: number };
type StructureSummary = { bias: 'BULLISH' | 'BEARISH' | 'RANGE'; points: StructurePoint[]; events: StructureEvent[]; summary: string; };

type AlertItem = { level: 'hot' | 'warn' | 'info' | 'ok'; title: string; message: string; symbol?: string; status?: string; distance?: number; score?: number; zone?: string; zone1h?: string; refinement?: string; htf?: string; trigger?: string; triggerPattern?: string; obQuality?: string; side?: 'LONG' | 'SHORT'; action?: string; currentPrice?: number; entryAggressive?: number; entryMain?: number; entryConservative?: number; stopLoss?: number; tp1?: number; tp2?: number; tp3?: number; telegramImageReady?: boolean };
type SniperMode = 'AGGRESSIVE' | 'NORMAL' | 'CONSERVATIVE';
type AlertMode = 'AGGRESSIVE' | 'NORMAL' | 'STRICT';
